			stringArrayRemoveAtIndex($indexarr, $animlienarr);
		}

		for ($tip = 0; $tip < size ($animlinmarr);++$tip){
			string $splitedResult[] = stringToStringArray($animlinmarr[$tip], "|");
			if (size($splitedResult) > 1)
				$animlinmarr[$tip] = $splitedResult[1];
		}

		stringArrayInsertAtIndex(($indexarr) , $animlinmarr, ($sellle + "_" + $frst + "-" + $fren));
		string $finpada;

		for ($tp = 0; $tp < size ($animlinmarr);++$tp){
			string $padString = "0";
			string $prt = (string)($tp+1);
			if((size ($prt))<2)
				for($i=0;$i<(2-(size ($prt)));$i++){
					$padString=$padString+"0" ;
				}
			$finpada = $padString+($tp +1);
			$animlinmarr[$tp] = $finpada + "|" + $animlinmarr[$tp];
		}
		AppendUndo();
		setAttr -type "string" AnimAssistant.AnimationClipName (stringArrayToString($animlinmarr, " "));
		stringArrayInsertAtIndex(($indexarr), $animlistarr, $frst);
		setAttr -type "string" AnimAssistant.StartFrame (stringArrayToString($animlistarr, " "));
		stringArrayInsertAtIndex(($indexarr), $animlienarr, $fren);
		setAttr -type "string" AnimAssistant.EndFrame (stringArrayToString($animlienarr, " "));


		textScrollList -e -ra $animli;
		$animlinm = `getAttr AnimAssistant.AnimationClipName`;
		$animlinmarr = stringToStringArray($animlinm, " ");
		for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
		}
	} else {
	}
	if ($fannm != ""){

		textScrollList -e -ra $animli;
		string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
		string $animlinmarr[] = stringToStringArray($animlinm, " ");
		for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
		}
		string $filteredList[];
		string $aite[] = `textScrollList -q -ai $animli`;
		int $i = 0;
		for ($each in $aite){
				   string $keyword_lower = `tolower $fannm`;
				   string $each_lower = `tolower $each`;
				   string $findMatch = `match $keyword_lower $each_lower `;
				   if ($findMatch == $keyword_lower ){
						$filteredList[$i] = $each;
						$i++;
				   }
		 }


		 textScrollList -edit -ra $animli;
		 for ($each in $filteredList){
			textScrollList -edit -append $each $animli;
		 }

	} else {
		textScrollList -e -ra $animli;
		$animlinm = `getAttr AnimAssistant.AnimationClipName`;
		$animlinmarr = stringToStringArray($animlinm, " ");
		for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
		}
	}
	textScrollList -e -sii ($objsfik[0]) $animli;

}

global proc moveAnimUP () {
	global string $animfl;
	global string $animli;
	string $fannm = `textField -q -tx $animfl`;
	string $objsall[] = `textScrollList -q -si $animli`;
	int $objssil[]= `textScrollList -q -sii $animli`;
	int $op;
	int $prevPos;
	int $prP[];
	if ($fannm == ""){
		for ($op=0;$op< `size $objssil`; ++$op){
			$prevPos = ( $objssil[$op] == 1 )?$objssil[$op]:($objssil[$op] - 1);
			$prP[$op] = $prevPos;
			string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
			string $animlist = `getAttr AnimAssistant.StartFrame`;
			string $animlien = `getAttr AnimAssistant.EndFrame`;
			string $animlinmarr[] = stringToStringArray($animlinm, " ");
			string $animlistarr[] = stringToStringArray($animlist, " ");
			string $animlienarr[] = stringToStringArray($animlien, " ");
			string $fsfr = $animlistarr[$objssil[$op]-1];
			string $enfr = $animlienarr[$objssil[$op]-1];
			string $nmfr = $animlinmarr[$objssil[$op]-1];
			stringArrayRemoveAtIndex(($objssil[$op]-1), $animlinmarr);
			stringArrayRemoveAtIndex(($objssil[$op]-1), $animlistarr);
			stringArrayRemoveAtIndex(($objssil[$op]-1), $animlienarr);


			stringArrayInsertAtIndex(($prevPos-1), $animlinmarr, $nmfr);
			stringArrayInsertAtIndex(($prevPos-1), $animlistarr, $fsfr);
			stringArrayInsertAtIndex(($prevPos-1), $animlienarr, $enfr);

			for ($tip = 0; $tip < size ($animlinmarr);++$tip){
				string $splitedResult[] = stringToStringArray($animlinmarr[$tip], "|");
				if (size($splitedResult) > 1)
					$animlinmarr[$tip] = $splitedResult[1];
			}

			for ($tp = 0; $tp < size ($animlinmarr);++$tp){
				string $padString = "0";
				string $prt = (string)($tp+1);
				if((size ($prt))<2)
					for($i=0;$i<(2-(size ($prt)));$i++){
						$padString=$padString+"0" ;
					}
					$finpada = $padString+($tp +1);
					$animlinmarr[$tp] = $finpada + "|" + $animlinmarr[$tp];
			}
			AppendUndo();
			setAttr -type "string" AnimAssistant.AnimationClipName (stringArrayToString($animlinmarr, " "));
			setAttr -type "string" AnimAssistant.StartFrame (stringArrayToString($animlistarr, " "));
			setAttr -type "string" AnimAssistant.EndFrame (stringArrayToString($animlienarr, " "));
			textScrollList -e -ra $animli;
			$animlinm = `getAttr AnimAssistant.AnimationClipName`;
			$animlinmarr = stringToStringArray($animlinm, " ");
			for ($ob in $animlinmarr){
				textScrollList -e -a $ob $animli;
			}
		}
		for ($bet in $prP){
			textScrollList -e -sii $bet  $animli;
		}
	}
}

global proc moveAnimDN () {

	global string $animfl;
	global string $animli;
	string $fannm = `textField -q -tx $animfl`;
	string $objsall[] = `textScrollList -q -si $animli`;
	int $objssil[]= `textScrollList -q -sii $animli`;
	int $nuit = `textScrollList -q -ni $animli`;
	int $op;
	int $prevPos;
	int $provPos;
	int $prP[];
	clear($prP);
	if ($fannm == ""){
		for ( $op = (`size $objssil` - 1); $op >= 0; --$op ){
			$prevPos = ( $objssil[$op] == 1 )?$objssil[$op]:($objssil[$op] - 1);
			$provPos = ( $objssil[$op] == 1 )?$objssil[$op]:($objssil[$op] + 1);
			$prP[$op] = $provPos;
			print $provPos;
			string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
			string $animlist = `getAttr AnimAssistant.StartFrame`;
			string $animlien = `getAttr AnimAssistant.EndFrame`;
			string $animlinmarr[] = stringToStringArray($animlinm, " ");
			string $animlistarr[] = stringToStringArray($animlist, " ");
			string $animlienarr[] = stringToStringArray($animlien, " ");
			string $fsfr = $animlistarr[$objssil[$op]-1];
			string $enfr = $animlienarr[$objssil[$op]-1];
			string $nmfr = $animlinmarr[$objssil[$op]-1];
			stringArrayRemoveAtIndex(($objssil[$op]-1), $animlinmarr);
			stringArrayRemoveAtIndex(($objssil[$op]-1), $animlistarr);
			stringArrayRemoveAtIndex(($objssil[$op]-1), $animlienarr);


			stringArrayInsertAtIndex(($objssil[$op]) , $animlinmarr, $nmfr);
			stringArrayInsertAtIndex(($objssil[$op]), $animlistarr, $fsfr);
			stringArrayInsertAtIndex(($objssil[$op]), $animlienarr, $enfr);

			for ($tip = 0; $tip < size ($animlinmarr);++$tip) {
				string $splitedResult[] = stringToStringArray($animlinmarr[$tip], "|");
				if (size($splitedResult) > 1)
					$animlinmarr[$tip] = $splitedResult[1];
			}

			for ($tp = 0; $tp < size ($animlinmarr);++$tp){
				string $padString = "0";
				string $prt = (string)($tp+1);
				if((size ($prt))<2)
				for($i=0;$i<(2-(size ($prt)));$i++){
					$padString=$padString+"0" ;
				}
				$finpada = $padString+($tp +1);
				$animlinmarr[$tp] = $finpada + "|" + $animlinmarr[$tp];
			}
			AppendUndo();
			setAttr -type "string" AnimAssistant.AnimationClipName (stringArrayToString($animlinmarr, " "));
			setAttr -type "string" AnimAssistant.StartFrame (stringArrayToString($animlistarr, " "));
			setAttr -type "string" AnimAssistant.EndFrame (stringArrayToString($animlienarr, " "));
			textScrollList -e -ra $animli;
			$animlinm = `getAttr AnimAssistant.AnimationClipName`;
			$animlinmarr = stringToStringArray($animlinm, " ");
			for ($ob in $animlinmarr){
				textScrollList -e -a $ob $animli;
			}
		}
		for ($bet in $prP){
			if ($bet <= $nuit){
				if ($bet == 1){
					textScrollList -e -sii ($bet+1)  $animli;
				} else {
					textScrollList -e -sii $bet  $animli;
				}
			}
		}
	}
}

global proc AnimExporter () {
	string $singleFilter = "Anim Assistant File (*.txt)";
	string $filePath[] = `fileDialog2 -fileFilter $singleFilter -dialogStyle 2`;
	if (size($filePath) == 0)
		return;
	int $filedId = `fopen ($filePath[0]) "w"` ;

	string $finfo = `getAttr AnimAssistant.AnimationClipName`;
	string $animlinmarr[] = stringToStringArray($finfo, " ");
	string $animlist = `getAttr AnimAssistant.StartFrame`;
	string $animlistarr[] = stringToStringArray($animlist, " ");
	string $animlien = `getAttr AnimAssistant.EndFrame`;
	string $animlienarr[] = stringToStringArray($animlien, " ");
	for ($it=0;$it<size($animlinmarr);++$it){
		string $splitedResult[] = stringToStringArray($animlinmarr[$it], "|");
		if (size($splitedResult) > 1)
			$animlinmarr[$it] = $splitedResult[1];
		string $seli = `substitute ("_" + ($animlistarr[$it]) + "-" + ($animlienarr[$it])) $animlinmarr[$it] ""`;
		fprint $filedId ($animlistarr[$it] + " " + $animlienarr[$it] + " " + $seli + "\r\n");
	}

	fclose $filedId ;
}

global proc AnimExporterSelected () {
	string $singleFilter = "Anim Assistant File (*.txt)";
	string $filePath[] = `fileDialog2 -fileFilter $singleFilter -dialogStyle 2`;
	if (size($filePath) == 0)
		return;
	int $filedId = `fopen ($filePath[0]) "w"` ;

	global string $animli;
	string $seli[] = `textScrollList -q -si $animli`;
	string $finfo = `getAttr AnimAssistant.AnimationClipName`;
	string $animlinmarr[] = stringToStringArray($finfo, " ");
	string $animlist = `getAttr AnimAssistant.StartFrame`;
	string $animlistarr[] = stringToStringArray($animlist, " ");
	string $animlien = `getAttr AnimAssistant.EndFrame`;
	string $animlienarr[] = stringToStringArray($animlien, " ");
	for ($it=0;$it<size($animlinmarr);++$it){
		int $indexarr = stringArrayFind( $animlinmarr[$it], 0, $seli );
		if ($indexarr >= 0 || size($seli) == 0) {
			string $splitedResult[] = stringToStringArray($animlinmarr[$it], "|");
			if (size($splitedResult) > 1){
				$animlinmarr[$it] = $splitedResult[1];
				string $seli = `substitute ("_" + ($animlistarr[$it]) + "-" + ($animlienarr[$it])) $animlinmarr[$it] ""`;
				fprint $filedId ($animlistarr[$it] + " " + $animlienarr[$it] + " " + $seli + "\r\n");
			}
		}
	}

	fclose $filedId ;
}

global proc AnimImporter () {
	global string $animli;
	string $dirName = dirname(`file -q -sn`) + "/*.txt";
	string $filePath = `fileDialog -dm $dirName`;
	if (size($filePath) == 0)
		return;
	int $filedId = `fopen ($filePath) "r"` ;
	string $dataArray[] ;
	string $animnmArr[];
	string $animstArr[];
	string $animenArr[];
	clear ($dataArray);
	int $exTest = `filetest -r $filePath`;
	string $nextLine = `fgetline $filedId` ;
	int $skipFirstLine;
	if ($exTest == 1){
		CreateIfNotExistNodeAttribute();
		while (size($nextLine) > 0) {
			string $cleanLine = strip($nextLine) ;
			$dataArray[size($dataArray)] = $cleanLine ;
			$nextLine = `fgetline $filedId` ;
		}
		if($skipFirstLine) stringArrayRemoveAtIndex(0,$dataArray) ;

		for ($ope=0; $ope<(size($dataArray));++$ope){
			string $tempostring[];
			int $ttttt = `tokenize $dataArray[$ope] " " $tempostring`;
			$animnmArr[$ope] = $tempostring[2] + "_" + $tempostring[0] + "-" + $tempostring[1];
			$animstArr[$ope] = $tempostring[0];
			$animenArr[$ope] = $tempostring[1];
		}

		for ($tp = 0; $tp < size ($animnmArr);++$tp){
			string $padString = "0";
			string $prt = (string)($tp+1);
			if((size ($prt))<2)
			for($i=0;$i<(2-(size ($prt)));$i++){

			$padString=$padString+"0" ;
			}
			$finpada = $padString+($tp +1);
			$animnmArr[$tp] = $finpada + "|" + $animnmArr[$tp];


		}

		string $annnm = stringArrayToString ($animnmArr, " ");
		string $annst = stringArrayToString ($animstArr, " ");
		string $annen = stringArrayToString ($animenArr, " ");
		AppendUndo();
		setAttr -type "string" AnimAssistant.AnimationClipName $annnm;
		setAttr -type "string" AnimAssistant.StartFrame $annst;
		setAttr -type "string" AnimAssistant.EndFrame $annen;

		textScrollList -e -ra $animli;
		for ($obg in $animnmArr){
		textScrollList -e -a $obg $animli;

		}
	}
}

global proc AnimLiUpdate (){
	global string $animli;
	int $grex = `objExists "AnimAssistant"`;
	if ($grex == 1){
		string $finfo = `getAttr AnimAssistant.AnimationClipName`;
		string $animlinmarr[] = stringToStringArray($finfo, " ");
		textScrollList -e -ra $animli;
		for ($obg in $animlinmarr){
			textScrollList -e -a $obg $animli;
		}
	} else {
		textScrollList -e -ra $animli;
	}
	UpdateCamerasList();
}

global proc AnimColorRange () {
	global string $animli;
	global string $animnm;
	int $objsfik[] = `textScrollList -q -sii $animli`;
	int $anlesit = `textScrollList -q -nsi $animli`;
	string $animlist = `getAttr AnimAssistant.StartFrame`;
	string $animlien = `getAttr AnimAssistant.EndFrame`;
	string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
	string $animlistarr[] = stringToStringArray($animlist, " ");
	string $animlienarr[] = stringToStringArray($animlien, " ");
	string $animlinmarr[] = stringToStringArray($animlinm, " ");
	float $colorP[] = `colorSliderGrp -q -rgb AnimationColor`;
	string $obli[] = `ls -sl -l`;

	string $objsfke[] = `textScrollList -q -si $animli`;
	int $indexarr = stringArrayFind( $objsfke[0], 0, $animlinmarr );
	  for ($zip = 0; $zip < $anlesit; ++$zip){
		int $indexarr = stringArrayFind( $objsfke[$zip], 0, $animlinmarr );
		int $stfr = (int)$animlistarr[$indexarr];
		int $enfr = (int)$animlienarr[$indexarr];


			for ($obi=0; $obi<(size($obli)); ++$obi) {
				float $ranum = `rand 0 999`;
				string $sranum = (string)$ranum;
				string $stranum = `substitute "\\." $sranum "_"`;
				string $ranname = "curveColor_" + $stranum;
				string $liscur[] = `listAttr -st "curveColor_*" $obli[$obi]`;
				string $shnm = `match "[^|\\]*$" $obli[$obi]`;
				for ($im in $liscur){
					cutKey -t $stfr -attribute $im -option keys -clear $obli[$obi];
					cutKey -t $enfr -attribute $im -option keys -clear $obli[$obi];
					float $qkeysak[] = `keyframe -q ($obli[$obi]+ "." + $im)`;
					float $qkeysa = `keyframe -q -kc ($obli[$obi]+ "." + $im)`;
					if ($qkeysak[0]<0 && $qkeysa<=1) {
					   deleteAttr -attribute $im $obli[$obi];

					}
				}

				addAttr -longName $ranname -k true -h true $obli[$obi];

				setKeyframe -t $stfr ($obli[$obi] + "." + $ranname);
				setKeyframe -t $enfr ($obli[$obi] + "." + $ranname);

				string $buffer[] ;
				tokenize $shnm ":" $buffer ;
				string $newName = $buffer[size($buffer)-1] ;

				setAttr ($newName + "_" + $ranname + ".curveColor") -type double3 $colorP[0] $colorP[1] $colorP[2] ;
				setAttr ($newName + "_" + $ranname + ".useCurveColor") 1;
				addAttr -longName ($ranname+"_red") -k true -h true $obli[$obi];
				setKeyframe -t -1 ($obli[$obi] + "." + $ranname +"_red");
				setAttr ($newName + "_" + $ranname + "_red.curveColor") -type double3 1 0 0 ;
				setAttr ($newName + "_" + $ranname  + "_red.useCurveColor") 1;
			}
	}

	 int $filex = `objExists "AnimAttr"`;
	  if ($filex == 0) {
		  itemFilterAttr -bn "curveColor_*" -neg true AnimAttr;
		  outlinerEditor -e -attrFilter "AnimAttr" graphEditor1OutlineEd;

	  } else {
		  outlinerEditor -e -attrFilter "AnimAttr" graphEditor1OutlineEd;
	  }


}

global proc AnimColorFill () {
	global string $animli;
	global string $animnm;
	int $objsfik[] = `textScrollList -q -sii $animli`;
	int $anlesit = `textScrollList -q -nsi $animli`;
	string $animlist = `getAttr AnimAssistant.StartFrame`;
	string $animlien = `getAttr AnimAssistant.EndFrame`;
	string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
