global proc string getFFmpegExe(){
	$ffmpegPathValue = `getenv "FFMPEG_PATH"`;
	if ($ffmpegPathValue != "") {
		$ffmpegPathValue = ($ffmpegPathValue + "/ffmpeg.exe");
		$fileExists = `filetest -x $ffmpegPathValue`;
		if (!$fileExists) {
			$ffmpegPathValue = ($ffmpegPathValue + "/ffmpeg");
			$fileExists = `filetest -x $ffmpegPathValue`;
			if (!$fileExists) {
				print("Not found ffmeg exe");
				return "";
			}
		}
		return $ffmpegPathValue;
	}
	return "";
}

global proc string PlayblastPBImpl(string $camera){
	global string $framest;
	global string $frameen;
	global string $animnm;
	global string $pbPath;
	global string $pbPostfix;
	global string $pbPrefix;
	string $getPath = `textField -q -tx $pbPath`;
	string $getPpostF = `textField -q -tx $pbPostfix`;
	string $getPreF = `textField -q -tx $pbPrefix`;

	string $getStFr = `textField -q -tx $framest`;
	string $getEnFr = `textField -q -tx $frameen`;
	string $getNmFr = `textField -q -tx $animnm`;
	string $fform = `optionVar -q playblastFormat`;
	float $percent = `optionVar -q playblastScale`;
	int $scale = $percent * 100;
	int $quality = `optionVar -q playblastQuality`;
	string $compress = `optionVar -q playblastCompression`;
	int $pad = `optionVar -q playblastPadding`;
	int $isViewer = `optionVar -q playblastViewerOn`;
	int $isShowOrnaments = `optionVar -q playblastShowOrnaments`;
	int $displaySizeSource = `optionVar -q playblastDisplaySizeSource`;
	int $width = 0;
	int $height = 0;
	if ($displaySizeSource == 3) {
		$width = `optionVar -q playblastWidth`;
		$height = `optionVar -q playblastHeight`;
	} else if ($displaySizeSource == 2) {
		$width = `getAttr "defaultResolution.width"`;
		$height = `getAttr "defaultResolution.height"`;
	}
	$ffmpegPathValue = `getenv "FFMPEG_PATH"`;
	if ($ffmpegPathValue != "") {
		//$fform = "avi";
		//$compress = "none";
		$isViewer = 0;
		if ($width % 2 != 0) {
			$width = $width + 1;
		}
		if ($height % 2 != 0) {
			$height = $height + 1;
		}
	}

	if ($getStFr!="" && $getEnFr!="" && $getNmFr!="" && $getPath!=""){
		string $name = "";
		if ($camera != "") {
			$getNmFr = $camera + "_" + $getNmFr;
		}
		if($getPreF!="" && $getPpostF==""){
			$name = ($getPath+"/"+$getPreF+"_"+$getNmFr);
		} else if ($getPreF=="" && $getPpostF!=""){
			$name = ($getPath+"/"+$getNmFr+"_"+$getPpostF);
		} else if ($getPreF!="" && $getPpostF!=""){
			$name = ($getPath+"/"+$getPreF+"_"+$getNmFr+"_"+$getPpostF);
		} else {
			$name = ($getPath+"/"+$getNmFr);
		}

		$cmd = "playblast -forceOverwrite -fmt "+$fform+" -p "+$scale+" -compression "+$compress+" -quality "+$quality+" -viewer "+$isViewer+" -showOrnaments "+$isShowOrnaments+" -fp "+$pad+" -st "+$getStFr+" -et "+$getEnFr+" -f "+$name+" -widthHeight "+$width+" "+$height;
		print($cmd+"\n");
		if ($displaySizeSource == 1) {
			playblast -forceOverwrite -fmt $fform -p $scale -compression $compress -quality $quality -viewer $isViewer -showOrnaments $isShowOrnaments -fp $pad -st $getStFr -et $getEnFr -f $name;
		} else {
			playblast -forceOverwrite -fmt $fform -p $scale -compression $compress -quality $quality -viewer $isViewer -showOrnaments $isShowOrnaments -fp $pad -st $getStFr -et $getEnFr -f $name -widthHeight $width $height;
		}
		
		if ($ffmpegPathValue != "") {
			$ffmpegPathValue = getFFmpegExe();
			$movieFileName = $name+".avi";
			$findResult = `filetest -r $movieFileName`;
			if (!$findResult) {
				$movieFileName = $name+".mov";
				$findResult = `filetest -r $movieFileName`;
				if (!$findResult) {
					print("FFmpeg input file not found");
					return "";
				}
			}
			$outputFileName = $name+".mp4";
			$commandToRun = ($ffmpegPathValue+" -y -i \""+$movieFileName+"\" -vcodec h264 \""+$outputFileName + "\"");
			print($commandToRun+"\n");
			print(system($commandToRun));
			print("----------End of ffmpeg-----------\n");
			if (`filetest -r $outputFileName`) {
				sysFile -delete $movieFileName;
			}
			else {
				return "";
			}
			return $outputFileName;
		}
	}
	return "";
}

global proc int PlayblastPBAnim(string $anim, string $view, string $gMainProgressBar){
	global string $camerasList;
	string $orthoCameras[] = `textScrollList -q -si $camerasList`;
	string $outFiles[];
	for ($camera in $orthoCameras) {
		lookThru $camera $view;
		$fileName = PlayblastPBImpl($camera);
		if(`progressBar -q -ic $gMainProgressBar`)
		{
			print ("Playblast canceled after " + $anim);
			return 0;
		}
		$outFiles[size($outFiles)] = $fileName;
	}
	if (size($orthoCameras) == 0) {
		PlayblastPBImpl("");
	}
	
	$ffmpegPathValue = getFFmpegExe();
	if (size($outFiles) > 1 && $ffmpegPathValue != "") {
		global string $pbPath;
		string $getPath = `textField -q -tx $pbPath`;
		global string $animnm;
		string $getNmFr = `textField -q -tx $animnm`;
		$outputFileName = $getPath + "/" + $getNmFr + ".mp4";
		$commandToRun = ($ffmpegPathValue+" -y ");
		for ($file in $outFiles) {
			$commandToRun = ($commandToRun + "-i \"" + $file + "\" ");
		}
		$commandToRun = ($commandToRun + "-filter_complex hstack \"" + $outputFileName + "\"");
		print("Try to merge cameras video");
		print($commandToRun + "\n");
		print(system($commandToRun));
	}

	return 1;
}

global proc PlayblastPB(){
	string $defaultCamera = `lookThru -q`;
	string $view = `getPanel -withFocus`;
	global string $gMainProgressBar;
	int $maxPBar = 10000;
	progressBar -e -bp -ii 1 -imp 1 -max $maxPBar $gMainProgressBar;
	
	global string $animli;
	string $objsfke[] = `textScrollList -q -si $animli`;
	for ($anim in $objsfke){
		SetAnimationClip($anim);
		if (PlayblastPBAnim($anim, $view, $gMainProgressBar) == 0) {
			break;
		}
		progressBar -e -s 1 $gMainProgressBar;
	}
	
	progressBar -e -endProgress $gMainProgressBar;
	lookThru $defaultCamera $view;
}

global proc AnimSel () {
	string $slobjec[] = `ls -sl`;
	global string $objectli;
	textScrollList -e -ra $objectli;
	for ($ob in $slobjec){
		textScrollList -e -a $ob $objectli;
	}
}

global proc doWrite (int $spacer) {
	global string $spa;
	if ($spacer == 1){
		$spa = "-objectSpace";
	} else {
		$spa = "-worldSpace";
	}
}

global proc AnimAssistMain () {
	global string $spa;
	string $slobje[] = `ls -sl`;
	group -empty -n ("one_f_tmp_grp");
	for ($z in $slobje){
		group -empty -n ($z+"_tmp_grp");
		parent ($z+"_tmp_grp") "one_f_tmp_grp";
	}
	float $sttr = `playbackOptions -q -min`;
	float $endtr = `playbackOptions -q -max`;
	float $i;
	for ( $i=$sttr; $i<=$endtr; ++$i ){
		float $crtm = `currentTime $i`;
		for ($k in $slobje){
			if(`keyframe -time $crtm -query -keyframeCount $k` != 0){
				float $positeo[] = `xform $spa -query -translation $k`;
				float $rotatio[] = `xform $spa -query -ro $k`;
				move -a $spa $positeo[0] $positeo[1] $positeo[2] ($k+"_tmp_grp");
				rotate -a $spa $rotatio[0] $rotatio[1] $rotatio[2] ($k+"_tmp_grp");
				setKeyframe -breakdown 0 ($k+"_tmp_grp");
			}
		}
	}
}

global proc moveItUP () {
	global string $objectli;
	string $objsall[] = `textScrollList -q -selectItem $objectli`;
	int $objssil[] = `textScrollList -q -selectIndexedItem $objectli`;
	for ($op=0;$op< `size $objssil`; ++$op){
		int $prevPos = ( $objssil[$op] == 1 )?$objssil[$op]:($objssil[$op] - 1);
		textScrollList -e -removeIndexedItem $objssil[$op] $objectli;
		textScrollList -e -appendPosition $prevPos $objsall[$op] $objectli;
		textScrollList -e -selectItem $objsall[$op] $objectli;
	}
}

global proc moveItDN () {
	global string $objectli;
	string $objsall[] = `textScrollList -q -selectItem $objectli`;
	int $objssil[] = `textScrollList -q -selectIndexedItem $objectli`;
	int $objsnam = `textScrollList -q -numberOfItems $objectli`;
	for ( $op = (`size $objssil` - 1); $op >= 0; --$op ) {
		int $nextPos = ( $objssil[$op] == $objsnam )?$objssil[$op]:($objssil[$op] + 1);
		textScrollList -e -removeIndexedItem $objssil[$op] $objectli;
		textScrollList -e -appendPosition $nextPos $objsall[$op] $objectli;
		textScrollList -e -selectItem $objsall[$op] $objectli;
	}
}



global proc RecIT () {
	global string $spa;
	global string $animrad;
	global string $objectli;
	string $sell[] = `ls -sl`;
	float $intag[];
	float $outtag[];
	int $loctag[];
	string $chanls[] = { ".translateX", ".translateY", ".translateZ", ".rotateX", ".rotateY", ".rotateZ" };
	string $slobje[] = `textScrollList -q -ai $objectli`;
	int $grex = `objExists "one_f_tmp_grp"`;
	if ($grex == 0){
		group -empty -n ("one_f_tmp_grp");
	}
	for ($z in $slobje){
		int $grexobj = `objExists ("|one_f_tmp_grp|" + $z+"_tmp_grp")`;
		if ($grexobj == 0){
			group -empty -n ($z+"_tmp_grp");
			int $ror = `getAttr ($z + ".rotateOrder")`;
			parent ("|" + $z+"_tmp_grp") "one_f_tmp_grp";
			setAttr ("|one_f_tmp_grp|" + $z+"_tmp_grp"+".rotateOrder") $ror;
		} else {
			delete ("|one_f_tmp_grp|" + $z+"_tmp_grp");
			group -empty -n ($z+"_tmp_grp");
			parent ("|" + $z+"_tmp_grp") "one_f_tmp_grp";
		}
	}
	string $k;

	float $fsfr;
	float $lsfr;
	float $sttr = `playbackOptions -q -min`;
	float $endtr = `playbackOptions -q -max`;

 	if (`keyframe  -t $sttr -q -kc $slobje`) {
		$fsfr = $sttr;
 	} else {
		$fsfr = `findKeyframe -time $sttr -which next $slobje`;
 	}
 	if (`keyframe  -t $endtr -q -kc $slobje`) {
		$lsfr = $endtr;
 	} else {
		$lsfr = `findKeyframe -time $endtr -which previous $slobje`;
	}
	currentTime -edit $fsfr;


	while ( `currentTime -q` != $lsfr) {
		float $crtm = `currentTime -q`;
		for ($k in $slobje){
			if(`keyframe -time $crtm -query -keyframeCount $k` != 0){
				if ($spa == "-objectSpace"){
					float $rota[] = `getAttr ($k + ".rotate")`;
					float $tra[] = `getAttr ($k + ".translate")`;
					setAttr ("|one_f_tmp_grp|" + $k+"_tmp_grp.translate") $tra[0] $tra[1] $tra[2];
					setAttr ("|one_f_tmp_grp|" + $k+"_tmp_grp.rotate") $rota[0] $rota[1] $rota[2];
					setKeyframe -breakdown 0 ("|one_f_tmp_grp|" + $k+"_tmp_grp");
				} else {
					float $positeo[] = `xform $spa -query -translation $k`;
					float $rotatio[] = `xform $spa -query -ro $k`;
					move -a $spa $positeo[0] $positeo[1] $positeo[2] ("|one_f_tmp_grp|" + $k+"_tmp_grp");
					rotate -a $spa $rotatio[0] $rotatio[1] $rotatio[2] ("|one_f_tmp_grp|" + $k+"_tmp_grp");
					setKeyframe -breakdown 0 ("|one_f_tmp_grp|" + $k+"_tmp_grp");
				}
				for ($zit=0;$zit<6;++$zit){
					int $obex = `objExists ($k + $chanls[$zit])`;
					if ($obex == 1){
						int $ktest = `keyframe  -t $crtm -q -kc ($k + $chanls[$zit])` ;
						if ($ktest == 1){
							$intag = `keyTangent -t $crtm -q -inAngle ($k + $chanls[$zit])` ;
							$outtag = `keyTangent -t $crtm -q -outAngle ($k + $chanls[$zit])` ;
							$loctag = `keyTangent -t $crtm -q -lock ($k + $chanls[$zit])` ;

							keyTangent -e -t $crtm -lock $loctag[0] ("|one_f_tmp_grp|" + $k +"_tmp_grp" + $chanls[$zit]);
							keyTangent -e -t $crtm -inAngle $intag[0]("|one_f_tmp_grp|" + $k +"_tmp_grp" + $chanls[$zit]);
							keyTangent -e -t $crtm -outAngle $outtag[0] ("|one_f_tmp_grp|" + $k +"_tmp_grp" + $chanls[$zit]);
						}
					}
				}
			}
		}
		currentTime -edit `findKeyframe  -which next $slobje`;
	}

	for ($k in $slobje){
		if(`keyframe -time $lsfr -query -keyframeCount $k` != 0){

			if ($spa == "-objectSpace"){
				float $rota[] = `getAttr ($k + ".rotate")`;
				float $tra[] = `getAttr ($k + ".translate")`;
				setAttr ("|one_f_tmp_grp|" + $k+"_tmp_grp.translate") $tra[0] $tra[1] $tra[2];
				setAttr ("|one_f_tmp_grp|" + $k+"_tmp_grp.rotate") $rota[0] $rota[1] $rota[2];
				setKeyframe -breakdown 0 ("|one_f_tmp_grp|" + $k+"_tmp_grp");
			} else {
				float $positeo[] = `xform $spa -query -translation $k`;
				float $rotatio[] = `xform $spa -query -ro $k`;
				move -a $spa $positeo[0] $positeo[1] $positeo[2] ("|one_f_tmp_grp|" + $k+"_tmp_grp");
				rotate -a $spa $rotatio[0] $rotatio[1] $rotatio[2] ("|one_f_tmp_grp|" + $k+"_tmp_grp");
				setKeyframe -breakdown 0 ("|one_f_tmp_grp|" + $k+"_tmp_grp");
			}

			for ($zit=0;$zit<6;++$zit){
				int $obex = `objExists ($k + $chanls[$zit])`;
				if ($obex == 1){
					int $ktest = `keyframe  -t $lsfr -q -kc ($k + $chanls[$zit])` ;
					if ($ktest == 1){
						$intag = `keyTangent -t $lsfr -q -inAngle ($k + $chanls[$zit])` ;
						$outtag = `keyTangent -t $lsfr -q -outAngle ($k + $chanls[$zit])` ;
						$loctag = `keyTangent -t $lsfr -q -lock ($k + $chanls[$zit])` ;

						keyTangent -e -t $lsfr -lock $loctag[0] ("|one_f_tmp_grp|" + $k +"_tmp_grp" + $chanls[$zit]);
						keyTangent -e -t $lsfr -inAngle $intag[0]("|one_f_tmp_grp|" + $k +"_tmp_grp" + $chanls[$zit]);
						keyTangent -e -t $lsfr -outAngle $outtag[0] ("|one_f_tmp_grp|" + $k +"_tmp_grp" + $chanls[$zit]);
					}
				}
			}
		}
	}
	string $clid[] = `listRelatives -c one_f_tmp_grp`;
	performEulerFilter graphEditor1FromOutliner;
	filterCurve $clid.rotateZ $clid.rotateY $clid.rotateX;
	select -r $sell;
}



global proc BakeKeys (){
	global string $spa;
	global string $animrad;
	global string $objectli;
	string $chanls[] = { ".translateX", ".translateY", ".translateZ", ".rotateX", ".rotateY", ".rotateZ" };
	int $nuse = `textScrollList -q -nsi $objectli`;
	int $nasel =`textScrollList -q -ni $objectli`;
	string $objsfk[];
	if ($nuse == $nasel || $nuse == 0){
		$objsfk = `textScrollList -q -ai $objectli`;
	} else {
		$objsfk = `textScrollList -q -si $objectli`;
	}
	string $les[] = `ls -sl`;

	string $clid[] = `listRelatives -c one_f_tmp_grp`;
	float $fsfr;
	float $lsfr;
	float $sttr = `playbackOptions -q -min`;
	float $endtr = `playbackOptions -q -max`;

	if (`keyframe  -t $sttr -q -kc $clid`) {
		$fsfr = $sttr;
	} else {
		$fsfr = `findKeyframe -time $sttr -which next $clid`;
	}
	if (`keyframe  -t $endtr -q -kc $clid`) {
		$lsfr = $endtr;
	} else {
		$lsfr = `findKeyframe -time $endtr -which previous $clid`;
	}
	currentTime -edit $fsfr;

	while (  `currentTime -q` != $lsfr) {
		float $crtim = `currentTime -q`;

		for ($m in $objsfk){
			string $actobj = "|one_f_tmp_grp|" + $m + "_tmp_grp";
			if(`keyframe -time $crtim -query -keyframeCount $actobj` != 0){

				if ($spa == "-objectSpace"){
					float $rota[] = `getAttr ($actobj + ".rotate")`;
					float $tra[] = `getAttr ($actobj + ".translate")`;
					if (`getAttr -l ($m + ".translateX")`==0){
						setAttr ($m + ".translateX") $tra[0];
					}
					if (`getAttr -l ($m + ".translateY")`==0){
						setAttr ($m + ".translateY") $tra[1];
					}
					if (`getAttr -l ($m + ".translateZ")`==0){
						setAttr ($m + ".translateZ") $tra[2];
					}
					if (`getAttr -l ($m + ".rotateX")`==0){
						setAttr ($m + ".rotateX") $rota[0];
					}
					if (`getAttr -l ($m + ".rotateY")`==0){
						setAttr ($m + ".rotateY") $rota[1];
					}
					if (`getAttr -l ($m + ".rotateZ")`==0){
						setAttr ($m + ".rotateZ") $rota[2];
					}
					setKeyframe -breakdown 0 $m ;
				} else {
					float $positeo[] = `xform $spa -query -translation $actobj`;
					float $rotatio[] = `xform $spa -query -ro $actobj`;
					move -a $spa $positeo[0] $positeo[1] $positeo[2] $m ;
					rotate -a $spa $rotatio[0] $rotatio[1] $rotatio[2] $m ;
					setKeyframe -breakdown 0 $m ;
				}

				for ($zit=0;$zit<6;++$zit){
					int $obex = `objExists ($m + $chanls[$zit])`;
					if ($obex == 1){
						int $ktest = `keyframe  -t $crtim -q -kc ($m + $chanls[$zit])` ;
						if ($ktest == 1){
							$intag = `keyTangent -t $crtim -q -inAngle ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;
							$outtag = `keyTangent -t $crtim -q -outAngle ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;
							$loctag = `keyTangent -t $crtim -q -lock ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;

							keyTangent -e -t $crtim -lock $loctag[0] ($m + $chanls[$zit]);
							keyTangent -e -t $crtim -inAngle $intag[0]($m + $chanls[$zit]);
							keyTangent -e -t $crtim -outAngle $outtag[0] ($m + $chanls[$zit]);
						}
					}
				}
			}
		}
		currentTime -e `findKeyframe -which next $clid`;
	}

	for ($m in $objsfk){
		string $actobj = "|one_f_tmp_grp|" + $m + "_tmp_grp";
		if(`keyframe -time $lsfr -query -keyframeCount $actobj` != 0){
			if ($spa == "-objectSpace"){
				float $rota[] = `getAttr ($actobj + ".rotate")`;

				float $tra[] = `getAttr ($actobj + ".translate")`;
				if (`getAttr -l ($m + ".translateX")`==0){
					setAttr ($m + ".translateX") $tra[0];
				}
				if (`getAttr -l ($m + ".translateY")`==0){
					setAttr ($m + ".translateY") $tra[1];
				}
				if (`getAttr -l ($m + ".translateZ")`==0){
					setAttr ($m + ".translateZ") $tra[2];
				}
				if (`getAttr -l ($m + ".rotateX")`==0){
					setAttr ($m + ".rotateX") $rota[0];
				}
				if (`getAttr -l ($m + ".rotateY")`==0){
					setAttr ($m + ".rotateY") $rota[1];
				}
				if (`getAttr -l ($m + ".rotateZ")`==0){
					setAttr ($m + ".rotateZ") $rota[2];
				}
				setKeyframe -breakdown 0 $m ;
			} else {
				float $positeo[] = `xform $spa -query -translation $actobj`;
				float $rotatio[] = `xform $spa -query -ro $actobj`;
				move -a $spa $positeo[0] $positeo[1] $positeo[2] $m ;
				rotate -a $spa $rotatio[0] $rotatio[1] $rotatio[2] $m ;
				setKeyframe -breakdown 0 $m ;
			}
			for ($zit=0;$zit<6;++$zit){
				int $obex = `objExists ($m + $chanls[$zit])`;
				if ($obex == 1){
					int $ktest = `keyframe  -t $lsfr -q -kc ($m + $chanls[$zit])` ;
					if ($ktest == 1){
						$intag = `keyTangent -t $lsfr -q -inAngle ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;
						$outtag = `keyTangent -t $lsfr -q -outAngle ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;
						$loctag = `keyTangent -t $lsfr -q -lock ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;

						keyTangent -e -t $lsfr -lock $loctag[0] ($m + $chanls[$zit]);
						keyTangent -e -t $lsfr -inAngle $intag[0]($m + $chanls[$zit]);
						keyTangent -e -t $lsfr -outAngle $outtag[0] ($m + $chanls[$zit]);
					}
				}
			}
		}
	}
	select -r $les;
}

global proc BakeAllKeys (){
	global string $spa;
	global string $animrad;
	global string $objectli;
	string $les[] = `ls -sl`;
	string $chanls[] = { ".translateX", ".translateY", ".translateZ", ".rotateX", ".rotateY", ".rotateZ" };
	int $nuse = `textScrollList -q -nsi $objectli`;
	int $nasel =`textScrollList -q -ni $objectli`;
	string $objsfk[];
	$objsfk = `textScrollList -q -ai $objectli`;

	string $clid[] = `listRelatives -c one_f_tmp_grp`;
	float $fsfr;
	float $lsfr;
	float $sttr = `playbackOptions -q -min`;
	float $endtr = `playbackOptions -q -max`;

	if (`keyframe  -t $sttr -q -kc $clid`) {
		$fsfr = $sttr;
	} else {
		$fsfr = `findKeyframe -time $sttr -which next $clid`;
	}
	if (`keyframe  -t $endtr -q -kc $clid`) {
		$lsfr = $endtr;
	} else {
		$lsfr = `findKeyframe -time $endtr -which previous $clid`;
	}
	currentTime -edit $fsfr;

	while (  `currentTime -q` != $lsfr) {
		float $crtim = `currentTime -q`;

		for ($m in $objsfk){
			string $actobj = "|one_f_tmp_grp|" + $m + "_tmp_grp";
			if(`keyframe -time $crtim -query -keyframeCount $actobj` != 0){
				float $positeo[] = `xform $spa -query -translation $actobj`;
				float $rotatio[] = `xform $spa -query -ro $actobj`;
				//string $objnm = `substitute "_tmp_grp" $m ""`;
				move -a $spa $positeo[0] $positeo[1] $positeo[2] $m ;
				rotate -a $spa $rotatio[0] $rotatio[1] $rotatio[2] $m ;
				setKeyframe -breakdown 0 $m ;

				for ($zit=0;$zit<6;++$zit){
					int $obex = `objExists ($m + $chanls[$zit])`;
					if ($obex == 1){
						int $ktest = `keyframe  -t $crtim -q -kc ($m + $chanls[$zit])` ;
						if ($ktest == 1){
							$intag = `keyTangent -t $crtim -q -inAngle ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;
							$outtag = `keyTangent -t $crtim -q -outAngle ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;
							$loctag = `keyTangent -t $crtim -q -lock ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;

							keyTangent -e -t $crtim -lock $loctag[0] ($m + $chanls[$zit]);
							keyTangent -e -t $crtim -inAngle $intag[0]($m + $chanls[$zit]);
							keyTangent -e -t $crtim -outAngle $outtag[0] ($m + $chanls[$zit]);
						}
					}
				}
			}
		}
		currentTime -e `findKeyframe -which next $clid`;
	}

	for ($m in $objsfk){
		string $actobj = "|one_f_tmp_grp|" + $m + "_tmp_grp";
		if(`keyframe -time $lsfr -query -keyframeCount $actobj` != 0){
			float $positeo[] = `xform $spa -query -translation $actobj`;
			float $rotatio[] = `xform $spa -query -ro $actobj`;
			//string $objnm = `substitute "_tmp_grp" $m ""`;
			move -a $spa $positeo[0] $positeo[1] $positeo[2] $m ;
			rotate -a $spa $rotatio[0] $rotatio[1] $rotatio[2] $m ;
			setKeyframe -breakdown 0 $m ;

			for ($zit=0;$zit<6;++$zit){
				int $obex = `objExists ($m + $chanls[$zit])`;
				if ($obex == 1){
					int $ktest = `keyframe  -t $lsfr -q -kc ($m + $chanls[$zit])` ;
					if ($ktest == 1){
						$intag = `keyTangent -t $lsfr -q -inAngle ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;
						$outtag = `keyTangent -t $lsfr -q -outAngle ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;
						$loctag = `keyTangent -t $lsfr -q -lock ("|one_f_tmp_grp|" + $m +"_tmp_grp" + $chanls[$zit])` ;

						keyTangent -e -t $lsfr -lock $loctag[0] ($m + $chanls[$zit]);
						keyTangent -e -t $lsfr -inAngle $intag[0]($m + $chanls[$zit]);
						keyTangent -e -t $lsfr -outAngle $outtag[0] ($m + $chanls[$zit]);
					}
				}
			}
		}
	}

	select -r $les;

}

global proc DeleteSys () {
	delete "one_f_tmp_grp";
}

global proc RenAmme () {
	global string $objectli;
	global string $objecttx;
	string $lss[] = `ls -sl`;
	string $nmsp = `match "^.*:" $lss[0]`;
	string $nmo[] = `ls -r 1 ("*" + $lss[0] + "*")`;
	string $nmse[] = `select -r $nmo[0]`;
	string $nmsp_name = `match "[^:]*$" $lss[0]`;
	string $grm[] = `listRelatives -c "one_f_tmp_grp"`;
	string $s;
	string $dr;

	for ($s in $grm){
		string $component = `match "[^:]*$" $s`;

		string $tmprem = `substitute "_tmp_grp" $component ""`;
		string $nmsptemp = `match "^.*:" $s`;
		if  ( $tmprem == $nmsp_name){
			for ($r in $grm){
				string $componentname = `match "[^:]*$" $r`;
				rename ("|one_f_tmp_grp|" + $r) ($nmsp + $componentname);
			}
		}
	}
	string $gram[] = `listRelatives -c "one_f_tmp_grp"`;
	textScrollList -e -ra $objectli;
	for ($obg in $gram){
		string $tamprem = `substitute "_tmp_grp" $obg ""`;
		textScrollList -e -a $tamprem $objectli;
	}

}


global proc DeleteAinm () {
	global string $objectli;
	string $objsall[] = `textScrollList -q -selectItem $objectli`;
	string $objsallinl[] = `textScrollList -q -ai $objectli`;
	string $objdiff[] = stringArrayRemoveExact($objsall, $objsallinl);
	int $grex = `objExists "one_f_tmp_grp"`;
	textScrollList -e -ra $objectli;
	if ($grex == 1 ){
		for ($ad in $objsall){
			delete ($ad + "_tmp_grp");
		}
	}
	for ($ob in $objdiff){
		textScrollList -e -a $ob $objectli;
	}
}


global proc SetDynRootKey () {
	float $pointpos[] = `xform -q -ws -t "Dinamic_pointer"`;
	float $pointrot[] = `xform -q -ws -ro "Dinamic_pointer"`;
	float $contpos[] = `xform -q -ws -t "Dinamic_cont"`;
	float $controt[] = `xform -q -ws -ro "Dinamic_cont"`;
	float $tm = `currentTime -query`;
	currentTime $tm;
	setKeyframe "Dinamic_root";
	setKeyframe "Dinamic_cont";
	currentTime ($tm+1);
	move -ws $pointpos[0] $pointpos[1] $pointpos[2] "Dinamic_root";
	rotate -ws $pointrot[0] $pointrot[1] $pointrot[2] "Dinamic_root";
	move -ws $pointpos[0] $pointpos[1] $pointpos[2] "Dinamic_pointer";
	rotate -ws $pointrot[0] $pointrot[1] $pointrot[2] "Dinamic_pointer";
	move -ws $contpos[0] $contpos[1] $contpos[2] "Dinamic_cont";
	rotate -ws $controt[0] $controt[1] $controt[2] "Dinamic_cont";
	setKeyframe "Dinamic_root";
	setKeyframe "Dinamic_cont";
	select -r "Dinamic_root";
}

global proc CreateDynRoot () {
	string $rots[] = `ls -sl`;
	if ($rots[0]!=""){
		float $boundingBox[] = `xform -q -bb $rots[0]`;
		$xSize = $boundingBox[3]-$boundingBox[0];
		circle -ch on -o on -nr 0 1 0 -c 0 0 0 -r ($xSize/2+4) -n "Dinamic_root";
		circle -ch on -o on -nr 0 1 0 -c 0 0 0 -r ($xSize/2+2) -n "Dinamic_cont";
		setAttr "Dinamic_contShape.visibility" 1;
		nurbsSquare -ch on -o on -nr 0 1 0 -sl1 ($xSize/2+ 7) -sl2 ($xSize/2 + 7) -c 0 0 0  -n "Dinamic_pointer_tmp";
		{
			string $sqobj[] = `listRelatives -c "Dinamic_pointer_tmp"`;
			$target = $sqobj[size($sqobj)-1];
			for ($p=0; $p<(size($sqobj)-1);++$p){
				parent $sqobj[$p] $target;
				makeIdentity -apply true -t 1 -r 1 -s 1 -n 0;
				$shp = `listRelatives -shapes`;
				select $shp;
				select -add $target;
				parent -s -r;
			}
		}
		select -r "Dinamic_pointer_tmp";
		ungroup;
		rename "Dinamic_pointer";
		{
			string $sqobj[] = `listRelatives -c -typ "transform"  "Dinamic_pointer"`;
			select $sqobj;
			delete;
		}
		parent "Dinamic_pointer" "Dinamic_root";
		float $objpos[] = `xform -q -ws -t $rots[0]`;
		float $objrot[] = `xform -q -ws -ro $rots[0]`;
		parent "Dinamic_cont" "Dinamic_root";
		move -ws $objpos[0] $objpos[1] $objpos[2] "Dinamic_root";
		rotate -ws $objrot[0] $objrot[1] $objrot[2] "Dinamic_root";
		parent $rots[0] "Dinamic_cont";
		setAttr "Dinamic_rootShape.overrideEnabled" 1;
		setAttr "Dinamic_rootShape.overrideRGBColors" 1;
		setAttr "Dinamic_rootShape.overrideColorRGB" 0.02 0.372359 1;
		setAttr "Dinamic_contShape.overrideEnabled" 1;
		setAttr "Dinamic_contShape.overrideRGBColors" 1;
		setAttr "Dinamic_contShape.overrideColorRGB" 0 0 0;
		setAttr "topDinamic_pointer_tmpShape.overrideEnabled" 1;
		setAttr "topDinamic_pointer_tmpShape.overrideRGBColors" 1;
		setAttr "topDinamic_pointer_tmpShape.overrideColorRGB" 0.737864 0.0951845 0.311821;
		setAttr "Dinamic_pointerShape.overrideEnabled" 1;
		setAttr "Dinamic_pointerShape.overrideRGBColors" 1;
		setAttr "Dinamic_pointerShape.overrideColorRGB" 0.737864 0.0951845 0.311821;
		setAttr "leftDinamic_pointer_tmpShape.overrideEnabled" 1;
		setAttr "leftDinamic_pointer_tmpShape.overrideRGBColors" 1;
		setAttr "leftDinamic_pointer_tmpShape.overrideColorRGB" 0.737864 0.0951845 0.311821;
		setAttr "bottomDinamic_pointer_tmpShape.overrideEnabled" 1;
		setAttr "bottomDinamic_pointer_tmpShape.overrideRGBColors" 1;
		setAttr "bottomDinamic_pointer_tmpShape.overrideColorRGB" 0.737864 0.0951845 0.311821;
	}
}

global proc DeleteDynRoot () {
	select "Dinamic_cont";
	string $lsch[] = `listRelatives -c -f`;
	if ($lsch[0]!=""){
		parent -world $lsch[1];
	}
	delete "Dinamic_root";

}

global proc ShapCont () {
	string $rotso[] = `ls -sl`;
	float $objposa[] = `xform -q -ws -t $rotso[0]`;
	float $objrosa[] = `xform -q -ws -ro $rotso[0]`;
	move -ws $objposa[0] $objposa[1] $objposa[2] "Dinamic_pointer";
	rotate -ws $objrosa[0] $objrosa[1] $objrosa[2] "Dinamic_pointer";
}

global proc RotPosContX () {
	float $objrosapX[] = `xform -q -os -ro Dinamic_pointer`;
	rotate -os ($objrosapX[0] + 90) $objrosapX[1] $objrosapX[2] "Dinamic_pointer";
}

global proc RotNegContX () {
	float $objrosanX[] = `xform -q -os -ro Dinamic_pointer`;
	rotate -os ($objrosanX[0] - 90) $objrosanX[1] $objrosanX[2] "Dinamic_pointer";
}

global proc RotPosContY () {
	float $objrosapY[] = `xform -q -os -ro Dinamic_pointer`;
	rotate -os $objrosapY[0] ($objrosapY[1] + 90) $objrosapY[2] "Dinamic_pointer";
}

global proc RotNegContY () {
	float $objrosanY[] = `xform -q -os -ro Dinamic_pointer`;
	rotate -os $objrosanY[0] ($objrosanY[1] - 90) $objrosanY[2] "Dinamic_pointer";
}

global proc RotPosContZ () {
	float $objrosapZ[] = `xform -q -os -ro Dinamic_pointer`;
	rotate -os $objrosapZ[0] $objrosapZ[1] ($objrosapZ[2] + 90) "Dinamic_pointer";
}

global proc RotNegContZ () {
	float $objrosanZ[] = `xform -q -os -ro Dinamic_pointer`;
	rotate -os $objrosanZ[0] $objrosanZ[1] ($objrosanZ[2] + 90) "Dinamic_pointer";
}

global proc AppendAnimName () {
	global string $framest;
	global string $frameen;
	global string $animli;
	global string $animnm;
	global string $animfl;
	string $qannm = `textField -q -tx $animnm`;
	string $fannm = `textField -q -tx $animfl`;
	string $ststfr = `textField -q -tx $framest` ;
	string $stenfr = `textField -q -tx $frameen` ;
	int $objsfik[] = `textScrollList -q -sii $animli`;
	if ($qannm != "" && $ststfr != "" && $stenfr != ""){
		int $frst = `textField -q -tx $framest`;
		int $fren = `textField -q -tx $frameen`;
		CreateIfNotExistNodeAttribute();

		string $objsfak[] = `textScrollList -q -si $animli`;

		$textFieldValue = `textField -q -tx $animnm`;

		//change attribute start
		string $sellle = `textField -q -tx $animnm`;
		while ( $sellle != ( $sellle = `substitute " " $sellle "_"` ) );
		string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
		string $animlinmarr[] = stringToStringArray($animlinm, " ");
		int $indexarr = stringArrayFind( $objsfak[0], 0, $animlinmarr );
		for ($tip = 0; $tip < size ($animlinmarr);++$tip){
			string $splitedResult[] = stringToStringArray($animlinmarr[$tip], "|");
			if (size($splitedResult) > 1)
				$animlinmarr[$tip] = $splitedResult[1];
		}

		stringArrayInsertAtIndex(($indexarr+1) , $animlinmarr, ($sellle + "_" + $frst + "-" + $fren));
		string $finpada;
		for ($tp = 0; $tp < size ($animlinmarr);++$tp){
			string $padString = "0";
			string $prt = (string)($tp+1);
			if((size ($prt))<2)
				for($i=0;$i<(2-(size ($prt)));$i++){
					$padString=$padString+"0" ;
				}
			$finpada = $padString+($tp +1);
			$animlinmarr[$tp] = $finpada + "|" + $animlinmarr[$tp];
		}
		AppendUndo();
		setAttr -type "string" AnimAssistant.AnimationClipName (stringArrayToString($animlinmarr, " "));
		//change attribute end

		//change attribute StFrame start
		string $animlist = `getAttr AnimAssistant.StartFrame`;
		string $animlistarr[] = stringToStringArray($animlist, " ");
		stringArrayInsertAtIndex(($indexarr+1), $animlistarr, $frst);
		setAttr -type "string" AnimAssistant.StartFrame (stringArrayToString($animlistarr, " "));
		//change attribute StFrame end
		//change attribute EnFrame start
		string $animlien = `getAttr AnimAssistant.EndFrame`;
		string $animlienarr[] = stringToStringArray($animlien, " ");
		stringArrayInsertAtIndex(($indexarr+1), $animlienarr, $fren);
		setAttr -type "string" AnimAssistant.EndFrame (stringArrayToString($animlienarr, " "));
		//change attribute EnFrame end

		textScrollList -e -ra $animli;
		$animlinm = `getAttr AnimAssistant.AnimationClipName`;
		$animlinmarr = stringToStringArray($animlinm, " ");
		for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
		}
		textScrollList -e -sii ($objsfik[0]+1) $animli;
	} else {
	}
	if ($fannm != ""){
		textScrollList -e -ra $animli;
		string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
		string $animlinmarr[] = stringToStringArray($animlinm, " ");
		for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
		}
		string $filteredList[];
		string $aite[] = `textScrollList -q -ai $animli`;
		int $i = 0;
		for ($each in $aite){
			string $keyword_lower = `tolower $fannm`;
			string $each_lower = `tolower $each`;
			string $findMatch = `match $keyword_lower $each_lower `;
			if ($findMatch == $keyword_lower ){
				$filteredList[$i] = $each;
				$i++;
			}
		}
		textScrollList -edit -ra $animli;
		for ($each in $filteredList){
			textScrollList -edit -append $each $animli;
		}

	} else {
		textScrollList -e -ra $animli;
		$animlinm = `getAttr AnimAssistant.AnimationClipName`;
		$animlinmarr = stringToStringArray($animlinm, " ");
		for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
		}
		textScrollList -e -sii ($objsfik[0]+1) $animli;
	}
}


global proc  AnimFilter() {
	global string $framest;
	global string $frameen;
	global string $animli;
	global string $animfl;
	global string $animnm;
	string $newnmstring;
	string $qannm = `textField -q -tx $animfl`;
	string $slit[] = `textScrollList -q -si $animli`;
	if ($qannm != ""){
		textScrollList -e -ra $animli;
		string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
		string $animlinmarr[] = stringToStringArray($animlinm, " ");
		for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
		}
		string $filteredList[];
		string $aite[] = `textScrollList -q -ai $animli`;
		int $i = 0;
		for ($each in $aite){
			string $keyword_lower = `tolower $qannm`;
			string $each_lower = `tolower $each`;
			string $findMatch = `match $keyword_lower $each_lower `;
			if ($findMatch == $keyword_lower ){
				$filteredList[$i] = $each;
				$i++;
			}
		}
		textScrollList -edit -ra $animli;
		for ($each in $filteredList){
			textScrollList -edit -append $each $animli;
		}
	} else {
		textScrollList -e -ra $animli;
		$animlinm = `getAttr AnimAssistant.AnimationClipName`;
		$animlinmarr = stringToStringArray($animlinm, " ");
		for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
		}
	}
	string $slot[] = `textScrollList -q -ai $animli`;
	for ($si in $slit){

			int $indexarr = stringArrayFind( $si, 0, $slot);
			if ( $indexarr >= 0){
				textScrollList -e -si $si $animli;
			}
		}

}

