global proc CleanWindow() {
	print "Found new version\n";
	if (`window -exists "Aassist"`){
		deleteUI -window "Aassist";
	}
	if( `dockControl -exists "AnimAssistantdock"` ){
		deleteUI "AnimAssistantdock";
	}
}


global proc AnimAssist () {
	global int $scriptVersion = 21;
	global string $window = "Aassist";
	global int $saveMWwidth;
	global string $history[];
	global string $historyStart[];
	global string $historyEnd[];
	$history = {};
	$historyStart = {};
	$historyEnd = {};
	$saveMWwidth = {};
	$ready = 0;
	string $dock = "AnimAssistantdock";
	if (`optionVar -ex AassistScriptVersion`){
		int $currentVersion = `optionVar -q AassistScriptVersion`;
		if ($scriptVersion != $currentVersion) {
			CleanWindow();
		}
	} else {
		CleanWindow();
	}
	optionVar -iv AassistScriptVersion $scriptVersion;
	$visibleDock = false;
	if (`window -exists $window`){
		// $saveMWwidth = `window -q -w $window`;
		window -e -visible true $window;
		$ready = 1;
	}
	if (windowExistsWithDock ($window)){
		window -e -visible true $window;
		$ready = 1;
	}
	if( `dockControl -exists $dock` ){
		$visibleDock = `dockControl -q -visible $dock`;
		dockControl -e -visible true $dock;
		$ready = 1;
	}
	if ($visibleDock){
		dockControl -e -visible false $dock;
	}
	if ($ready) {
		// UpdateCamerasList();
		updateAnims();
		return;
	}

	float $blue[];
	float $orange[];
	float $green[];
	float $red[];
	float $navRed[];
	float $navGreen[];
	float $navBlue[];

	/* ---START--- Color scheme, 0 - uncolored buttons, 1 - colored buttons // Öâĺňîâŕ˙ ńőĺěŕ, 0 - áĺńöâĺňíűĺ ęíîďęč, 1 - öâĺňíűĺ ęíîďęč ---ÍŔ×ŔËÎ--- */
	int $AnimColoredButtons = 0;
	/* ---END--- Color scheme, 0 - uncolored buttons, 1 - colored buttons // Öâĺňîâŕ˙ ńőĺěŕ, 0 - áĺńöâĺňíűĺ ęíîďęč, 1 - öâĺňíűĺ ęíîďęč ---ĘÎÍĹÖ--- */


	if ($AnimColoredButtons == 1){
		$blue = {0.0, 0.54, 1.0};
		$orange = {0.89, 0.392, 0.2156};
		$green = {0.407843, 0.631373, 0.188235};
		$red = {1.0, 0.2196, 0.0117};
		$navRed = {0.7, 0.2, 0.2};
		$navGreen = {0.2, 0.7, 0.2};
		$navBlue = {0.2, 0.2, 0.7};
	} else {
		$blue = {0.255, 0.539, 0.7012};
		$orange = {0.255, 0.539, 0.7012};
		$green = {0.255, 0.539, 0.7012};
		$red =  {0.255, 0.539, 0.7012};
		$navRed =  {0.255, 0.539, 0.7012};
		$navGreen =  {0.255, 0.539, 0.7012};
		$navBlue =  {0.255, 0.539, 0.7012};

	}


	string $windowTitle = "AnimAssistant";

	window -t $windowTitle -width 300 $window;

	scriptJob -e SceneOpened AnimLiUpdate;
	//scriptJob -e cameraChange UpdateCamerasList;

	string $pane = "myPane";
	/*---------------WINDOW DIVIDER------------------*/
	global string $AnimSep;

	$AnimSep = `paneLayout -smc "SepRemember" -configuration "horizontal2" -p $window $pane`;

	/*---------------WINDOW DIVIDER - Top main window------------------*/
	formLayout -p $pane  -w 243 -h 340 AnimAssistMainWindow;

	text -al "center"  -h 22  -l "Anim Manager" -ebg true -bgc 0 0 0 AnimManagerTitle;
	global string $animfl;
	$animfl = `textField -h 25 -w 213 -ann "filter" -cc "AnimFilter" -ec "AnimFilter" -p "AnimAssistMainWindow" -aie true AnimationFilterField`;
	popupMenu;
	menuItem -l "Filter" -c ( "AnimFilter" );
	menuItem -l "Clear" -c ( "ClearFlField" );

	global string $undoButton;
	$undoButton = `iconTextButton -w 20 -h 20 -style "iconOnly" -image "undo_icon_20" -c "UndoAction" -label "undo" undoButtonInstance`;

	global string $animli;
	$animli = `textScrollList -w 243 -h 10 -ams true -sc "SelectAnimClip" -dcc "FocusAnimClip" -dkc "RemoveAnimName" -p "AnimAssistMainWindow" animlister`;
	popupMenu;
	menuItem -l "Delete selected" -c ( "RemoveAnimName" );
	menuItem -l "Store takes" -c ( "StoreTakes" );
	menuItem -l "Export to GameExp" -c ( "ExptoTOGame" );
	menuItem -l "Export" -c ( "AnimExporter" );
	menuItem -l "Export Selected" -c ( "AnimExporterSelected" );
	menuItem -l "Import" -c ( "AnimImporter" );
	menuItem -l "Refresh list" -c ( "RefreshAnimList" );

	global string $animnm;
	$animnm = `textField  -h 25 -ann "animation name" -ec "AppendAnimName" -p "AnimAssistMainWindow" -aie true AnimationNameField`;
	popupMenu;
	menuItem -l "Edit" -c ( "RenNmField" );
	menuItem -l "Clear" -c ( "ClearNmField" );
	menuItem -l "Clear all" -c ( "ClearAllField" );
	formLayout -p "AnimAssistMainWindow"  -w 202 -h 28 AnimManButtons;
	button -backgroundColor  $blue[0] $blue[1] $blue[2]  -label "^" -w 25 -h 28 -c "moveAnimUP" -p "AnimManButtons" moveAnimUPbutton;
	button -backgroundColor  $blue[0] $blue[1] $blue[2]  -label "v" -w 25 -h 28 -c "moveAnimDN" -p "AnimManButtons" moveAnimDNbutton;
	button -backgroundColor  $orange[0] $orange[1] $orange[2]  -label "pick" -w 32 -h 28 -c "FrameInst" -p "AnimManButtons" FrameInstbutton;
	button -backgroundColor  $green[0] $green[1] $green[2] -label "+" -w 25 -h 28 -c "AppendAnimName" -p "AnimManButtons" AppendAnimNamebutton;
	button -backgroundColor  $red[0] $red[1] $red[2]  -label "-" -w 25 -h 28 -c "RemoveAnimName"  -p "AnimManButtons" RemoveAnimNamebutton;
	/*---------------Anim manager fields (START FRAME and END FRAME)------------------*/
	global string $framest;
	global string $frameen;
	global string $frameco;
	$framest = `textField -w 48 -h 25 -ann "start frame" -ec "AppendAnimName" -p "AnimManButtons" -aie true startframefield`;
	popupMenu;
	menuItem -l "Edit" -c ( "RenNmField" );
	menuItem -l "Clear" -c ( "ClearStField" );
	menuItem -l "Clear all" -c ( "ClearAllField" );
	$frameen = `textField -w 48 -h 25 -ann "end frame" -ec "AppendAnimName" -p "AnimManButtons" -aie true endframefield`;
	popupMenu;
	menuItem -l "Edit" -c ( "RenNmField");
	menuItem -l "Offset" -c ( "AnimOffset" );
	menuItem -l "Clear" -c ( "ClearEnField" );
	menuItem -l "Clear all" -c ( "ClearAllField" );
	$frameco = `text -al "center"  -h 22 -l " 0 " -p "AnimManButtons" countframefiled`;
	/*---------------Cameras frame START------------------*/
	formLayout -p $pane  -w 243 -h 340 AnimAssistBottomWindow;
	text -al "center"  -h 22 -l "Cameras" -ebg true -bgc 0 0 0 -p "AnimAssistBottomWindow" CamerasTitle;
	global string $camerasList;
	// $animli = `textScrollList -w 243 -h 10 -ams true -sc "SelectAnimClip" -dcc "FocusAnimClip" -dkc "RemoveAnimName" -p "AnimAssistMainWindow" animlister`;
	$camerasList = `textScrollList -w 243 -h 10 -ams true -dcc "SetCamera" -p "AnimAssistBottomWindow" cameraslister`;
	popupMenu;
	menuItem -l "Update Cameras" -c ( "UpdateCamerasList" );
	/*---------------Playblast frame START------------------*/
	text -al "center"  -h 22 -l "Playblast" -ebg true -bgc 0 0 0 -p "AnimAssistMainWindow" PlayblastTitle;
	global string $pbPath;
	$pbPath  = `textField -h 25 -ann "file path" -ec "PathEdPB" -cc "PathEdPB" -p "AnimAssistMainWindow" -aie true pathfield`;
	global string $ffmpegPath;
	$ffmpegPath  = `textField -h 25 -ann "ffmpeg path" -ec "PathEdFfmpeg" -cc "PathEdFfmpeg" -p "AnimAssistMainWindow" -aie true pathffmpegfield`;
	$ffmpegPathValue = `getenv "FFMPEG_PATH"`;
	textField -e -tx $ffmpegPathValue $ffmpegPath;
	global string $pbPrefix;
	$pbPrefix = `textField -w 70 -h 25 -ann "name prefix" -ec "PreEdPB" -cc "PreEdPB" -p "AnimAssistMainWindow" -aie true nameprefixfield`;
	popupMenu;
	menuItem -l "<= Paste frames" -c ( "PastePrePBSt" );
	menuItem -l "Paste frames =>" -c ( "PastePrePBEn" );

	global string $pbPostfix;
	$pbPostfix = `textField -w 70 -h 25 -ann "name postfix" -ec "PostEdPB" -cc "PostEdPB" -p "AnimAssistMainWindow" -aie true namepostfixfield`;
	popupMenu;
	menuItem -l "<= Paste frames" -c ( "PastePostPBSt" );
	menuItem -l "Paste frames =>" -c ( "PastePostPBEn" );
	button -backgroundColor  $orange[0] $orange[1] $orange[2]  -label "Browse" -w 72 -h 28 -c "BrowsePB"  -p "AnimAssistMainWindow" Browsebutton;
	button -backgroundColor  $orange[0] $orange[1] $orange[2]  -label "FFmpeg" -w 72 -h 28 -c "BrowseFfmpeg"  -p "AnimAssistMainWindow" BrowseFfmpegbutton;
	button -backgroundColor  $green[0] $green[1] $green[2] -label "Playblast" -w 52 -h 28 -c "PlayblastPB" -p "AnimAssistMainWindow" Playblastbutton;
	button -backgroundColor  $green[0] $green[1] $green[2] -label "(i)" -w 20 -h 28 -c "PlayblastConfig" -p "AnimAssistMainWindow" PlayblastbuttonConfig;
	text -al "center"  -h 22 -l "prefix | postfix" -p "AnimAssistMainWindow" PlayblastNameText;
	/*---------------Playblast------------------*/
	formLayout -edit -w 300 -h 28
		-af AnimManagerTitle left 0
		-af AnimManagerTitle right 0
		-af AnimManagerTitle top 0
		-ac AnimationFilterField top 2 AnimManagerTitle
		-af AnimationFilterField left 3
		-af AnimationFilterField right 25
		-ac undoButtonInstance top 2 AnimManagerTitle
		-af undoButtonInstance right 3
		-ac undoButtonInstance left 2 AnimationFilterField
		-ac undoButtonInstance bottom 3 animlister
		-ac animlister top 2 AnimationFilterField
		-af animlister left 2
		-af animlister right 2
		-ac animlister bottom 3 AnimationNameField
		-af AnimationNameField left 3
		-af AnimationNameField right 3
		-ac AnimationNameField bottom 3 AnimManButtons

		-af AnimManButtons left 3
		-ac AnimManButtons bottom 3 PlayblastTitle
		-af AnimManButtons right 3

		-af PlayblastTitle left 0
		-af PlayblastTitle right 0
		-ac PlayblastTitle bottom 0 nameprefixfield
		-ac PlayblastTitle bottom 0 PlayblastNameText
		-ac PlayblastTitle bottom 0 namepostfixfield
		-ac PlayblastTitle bottom 4 Playblastbutton
		-ac PlayblastTitle bottom 4 PlayblastbuttonConfig

		-af nameprefixfield left 2
		-ac nameprefixfield right 3 PlayblastNameText
		-ac nameprefixfield bottom 4 pathfield

		-ac PlayblastNameText bottom 6 pathfield
		-ac PlayblastNameText right 3 namepostfixfield

		-ac namepostfixfield right 3 Playblastbutton
		-ac namepostfixfield bottom 4 pathfield

		-ac Playblastbutton right 0 PlayblastbuttonConfig
		-ac Playblastbutton bottom 2 Browsebutton

		-af PlayblastbuttonConfig right 3	
		-ac PlayblastbuttonConfig bottom 2 Browsebutton

		-af pathfield left 2
		-ac pathfield bottom 5 pathffmpegfield
		-ac pathfield right 2 Browsebutton

		-af Browsebutton right 3
		-ac Browsebutton bottom 2 BrowseFfmpegbutton

		-af pathffmpegfield left 2
		-ac pathffmpegfield right 2 BrowseFfmpegbutton
		-af pathffmpegfield bottom 5

		-af BrowseFfmpegbutton bottom 3
		-af BrowseFfmpegbutton right 3

		AnimAssistMainWindow;

	formLayout -edit -w 300 -h 28
		-af CamerasTitle left 0
		-af CamerasTitle right 0
		-af CamerasTitle top 0
		-ac cameraslister top 3 CamerasTitle
		-af cameraslister left 2
		-af cameraslister right 2
		-af cameraslister bottom 3
		AnimAssistBottomWindow;

	formLayout -edit -w 300 -h 28
		-af moveAnimUPbutton bottom 0
		-ac moveAnimDNbutton left 2 moveAnimUPbutton
		-af moveAnimDNbutton bottom 0
		-ac FrameInstbutton left 2 moveAnimDNbutton
		-af FrameInstbutton bottom 0
		-ac AppendAnimNamebutton left 2 FrameInstbutton
		-af AppendAnimNamebutton bottom 0
		-ac RemoveAnimNamebutton left 2 AppendAnimNamebutton
		-af RemoveAnimNamebutton bottom 0
		-af startframefield bottom 2
		-ac startframefield left 2 RemoveAnimNamebutton
		-af endframefield bottom 2
		-ac endframefield left 2 startframefield
		-af countframefiled bottom 2
		-af countframefiled right 0
		-ac countframefiled left 6 endframefield
		AnimManButtons;

	window -edit -s true -widthHeight 246.0 341.0 $window;
	{

		string $dockSide = "left";
		int $dockFloating = 0;
		string $dockInfo[] = {};
		if (`optionVar -ex AAssistDock`) {
			$dockInfo = `optionVar -q AAssistDock`;
			$dockSide = $dockInfo[0];
			$dockFloating = $dockInfo[1];
		}
		if (`dockControl -ex $dock`) {
			deleteUI $dock;
		}
		{
			dockControl -aa right -aa left -area $dockSide -content $window -l "Anim Assistant" -fcc AAssistSavePosition -fl $dockFloating $dock;
		}
	}
	int $grex = `objExists "AnimAssistant"`;
	if ($grex == 1){
		string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
		string $animlinmarr[] = stringToStringArray($animlinm, " ");
		for ($bip in $animlinmarr) {
			textScrollList -e -a $bip $animli;
		}

		string $lstArrtA[] = `listAttr -ud AnimAssistant`;
		int $iPlayblastPt = stringArrayFind( "PlayblastPt", 0, $lstArrtA );
		if ($iPlayblastPt!=-1){
			string $PlayblastPtAttr = `getAttr AnimAssistant.PlayblastPt`;
			if($PlayblastPtAttr!=""){
				textField -e -tx $PlayblastPtAttr $pbPath;
			}
		}
		int $iPlayblastPost = stringArrayFind( "PlayblastPost", 0, $lstArrtA );
		if ($iPlayblastPost!=-1){
			string $PlayblastPostAttr = `getAttr AnimAssistant.PlayblastPost`;
			if($PlayblastPostAttr!=""){
				textField -e -tx $PlayblastPostAttr $pbPostfix;
			}
		}
		int $iPlayblastPre = stringArrayFind( "PlayblastPre", 0, $lstArrtA );
		if ($iPlayblastPre!=-1){
			string $PlayblastPreAttr = `getAttr AnimAssistant.PlayblastPre`;
			if($PlayblastPreAttr!=""){
				textField -e -tx $PlayblastPreAttr $pbPrefix;
			}
		}
	}
	UpdateCamerasList();
	global string $spa;
	$spa = "-worldSpace";
	if($saveMWwidth>0){
		optionVar -iv OsaveMWwidth $saveMWwidth;
		// window -e -w $saveMWwidth $window;
		// formLayout -e -w $saveMWwidth AnimAssistMainWindow;
		// dockControl -e -w $saveMWwidth $dock;
		// formLayout -e -w 248 AnimAssistMainWindow;
	} else {
		if (`optionVar -ex OsaveMWwidth`){
			int $OvarWidthW = `optionVar -q OsaveMWwidth`;
			// window -e -w $OvarWidthW $window;
			// formLayout -e -w $OvarWidthW AnimAssistMainWindow;
			// dockControl -e -w $OvarWidthW $dock;
			// formLayout -e -w 248 AnimAssistMainWindow;
		}
	}
	if (`optionVar -ex AAWin`){
		int $AAInfo[] = {};
		$AAInfo = `optionVar -q AAWin`;
		paneLayout -e -ps 1 100 $AAInfo[0] -ps 2 100 $AAInfo[1] $pane;
	}
	scriptJob -event "quitApplication" optawidth;
}


//////////////////////////////////////////////////////////////////////////////////////////////////

global proc updateAnims() {
	global string $animli;
	int $grex = `objExists "AnimAssistant"`;
	if ($grex == 1){
		textScrollList -e -ra $animli;
		string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
		string $animlinmarr[] = stringToStringArray($animlinm, " ");
		print("AnimAssistant check:\n");
		for ($bip in $animlinmarr) {
			textScrollList -e -a $bip $animli;
		}
	}
}

global proc UndoAction() {
	global string $history[];
	global string $historyStart[];
	global string $historyEnd[];
	global string $framest;
	global string $frameen;
	global string $animnm;
	global string $frameco;
	global string $animli;
	if (size($history) > 0) {
		int $indexSelected[] = `textScrollList -q -selectIndexedItem $animli`;
		string $animlinm = $history[size($history) - 1];
		stringArrayRemoveAtIndex(size($history) - 1, $history);
		string $animFrameStart = $historyStart[size($historyStart) - 1];
		stringArrayRemoveAtIndex(size($historyStart) - 1, $historyStart);
		string $animFrameEnd = $historyEnd[size($historyEnd) - 1];
		stringArrayRemoveAtIndex(size($historyEnd) - 1, $historyEnd);
		setAttr -type "string" AnimAssistant.AnimationClipName $animlinm;
		setAttr -type "string" AnimAssistant.StartFrame $animFrameStart;
		setAttr -type "string" AnimAssistant.EndFrame $animFrameEnd;
		AnimLiUpdate();
		if (size($indexSelected) > 0) {
			textScrollList -e -selectIndexedItem $indexSelected[0] $animli;
			SelectAnimClip();
		} else {
			textField -e -tx "" $framest;
			textField -e -tx "" $frameen;
			textField -e -tx "" $animnm;
			text -e -l "0" $frameco;
		}
	}
}

global proc AppendUndo() {
	global string $history[];
	global string $historyStart[];
	global string $historyEnd[];
	string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
	string $animFrameStart = `getAttr AnimAssistant.StartFrame`;
	string $animFrameEnd = `getAttr AnimAssistant.EndFrame`;
	if (size($history) > 0) {
		if ($history[size($history) - 1] == $animlinm) {
			return;
		}
	}
	stringArrayInsertAtIndex(size($history), $history, $animlinm);
	stringArrayInsertAtIndex(size($historyStart), $historyStart, $animFrameStart);
	stringArrayInsertAtIndex(size($historyEnd), $historyEnd, $animFrameEnd);
}

global proc string FindAnimationFullName(string $name) {
	if (size($name) < 5) return $name;
	string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
	string $animlinmarr[] = stringToStringArray($animlinm, " ");
	for ($anim in $animlinmarr) {
		string $shortName = `substitute ($name + "_[0-9]*-[0-9]") $anim $name`;
		if ($shortName == $name) {
			return $anim;
		}
	}
	return $name;
}

global proc PlayblastConfig() {
	performPlayblast 4;
}

global proc SetCamera(){
	global string $camerasList;
	string $camerasSelected[] = `textScrollList -q -si $camerasList`;
	if (size($camerasSelected) != 0) {
		string $view = `getPanel -withFocus`;
		lookThru $camerasSelected[0] $view;
	}
}

global proc UpdateCamerasList() {
	global string $camerasList;
	textScrollList -e -removeAll $camerasList;
	string $orthoCameras[] = `listCameras`;
	for ($camera in $orthoCameras) {
		$visible = `getAttr ($camera + ".visibility")`;
		if ($visible == "1") {
			textScrollList -e -a $camera $camerasList;
		}
		// scriptJob -attributeChange ($camera + ".visibility") UpdateCamerasList;
	}
}

global proc UpdateCamera(string $camera) {

}

global proc optawidth(){
	AnimAssist;
}

global proc int floatToInt(float $float)
{
	int $int = $float;
	return $int;
}

global proc int mayaVersion()
{
	return (floatToInt(`getApplicationVersionAsFloat`));
}

global proc int windowExistsWithDock (string $window)
{
	string $dock = $window + "Dock";

	if (mayaVersion() >= 2011)
		{
		if (!`dockControl -q -ex $dock`)
			return 0;
		if (!`dockControl -q -vis $dock`)
			return 0;
		}

	int $num = forInNum ($window, `lsUI -wnd`);
	if ($num == -1)
		return 0;
	else
		return 1;
}

global proc AAssistSavePosition() {
	string $dock	= "AnimAssistantdock";
	if (!`dockControl -q -ex $dock`)
		return;
	optionVar -sv AAssistDock (`dockControl -q -a $dock`);
	optionVar -sva AAssistDock (`dockControl -q -fl $dock`);
}

/*--------------Remember separator position------------*/
global proc SepRemember(){
	global string $AnimSep;
	int $AAInfo[] = {};
	int $sepValue[] = `paneLayout -q -ps $AnimSep`;
	if($sepValue[1]<80){
		optionVar -iv AAWin ($sepValue[1]);
		optionVar -iva AAWin ($sepValue[3]);
	} else {
		optionVar -iv AAWin 100;
		optionVar -iva AAWin 0;
	}
}

global proc CreateIfNotExistNodeAttribute() {
	int $grex = `objExists "AnimAssistant"`;
	if ($grex == 0){
		createNode "geometryVarGroup" -ss -n "AnimAssistant";
		addAttr -dt "string" -longName "AnimationClipName" AnimAssistant;
		addAttr -dt "string" -longName "StartFrame" AnimAssistant;
		addAttr -dt "string" -longName "EndFrame" AnimAssistant;
		addAttr -dt "string" -longName "PlayblastPt" AnimAssistant;
		addAttr -dt "string" -longName "PlayblastPost" AnimAssistant;
		addAttr -dt "string" -longName "PlayblastPre" AnimAssistant;
	}
}


/*---------------Playblast Path -------------*/
global proc BrowsePB(){
	global string $pbPath;
	CreateIfNotExistNodeAttribute();
	string $lstArrtA[] = `listAttr -ud AnimAssistant`;
	int $iPlayblastPt = stringArrayFind( "PlayblastPt", 0, $lstArrtA );
	if ($iPlayblastPt==-1){
		addAttr -dt "string" -longName "PlayblastPt" AnimAssistant;
	}
	int $iPlayblastPost = stringArrayFind( "PlayblastPost", 0, $lstArrtA );
	if ($iPlayblastPost==-1){
		addAttr -dt "string" -longName "PlayblastPost" AnimAssistant;
	}
	int $iPlayblastPre = stringArrayFind( "PlayblastPre", 0, $lstArrtA );
	if ($iPlayblastPre==-1){
		addAttr -dt "string" -longName "PlayblastPre" AnimAssistant;
	}
	string $result[] = `fileDialog2 -fm 3`;

	setAttr -type "string" AnimAssistant.PlayblastPt ($result[0]);

	textField -e -tx $result[0] $pbPath;
}

global proc BrowseFfmpeg(){
	global string $ffmpegPath;
	string $result[] = `fileDialog2 -fm 3`;
	
	putenv "FFMPEG_PATH" $result[0];

	textField -e -tx $result[0] $ffmpegPath;
}

global proc PathEdFfmpeg(){
	global string $ffmpegPath;
	string $getPath = `textField -q -tx $ffmpegPath`;
	putenv "FFMPEG_PATH" $getPath;
}

global proc PathEdPB(){
	global string $pbPath;
	string $getPath = `textField -q -tx $pbPath`;
	CreateIfNotExistNodeAttribute();
	string $lstArrtA[] = `listAttr -ud AnimAssistant`;
	int $iPlayblastPt = stringArrayFind( "PlayblastPt", 0, $lstArrtA );
	if ($iPlayblastPt==-1){
		addAttr -dt "string" -longName "PlayblastPt" AnimAssistant;
	}
	int $iPlayblastPost = stringArrayFind( "PlayblastPost", 0, $lstArrtA );
	if ($iPlayblastPost==-1){
		addAttr -dt "string" -longName "PlayblastPost" AnimAssistant;
	}
	int $iPlayblastPre = stringArrayFind( "PlayblastPre", 0, $lstArrtA );
	if ($iPlayblastPre==-1){
		addAttr -dt "string" -longName "PlayblastPre" AnimAssistant;
	}
	setAttr -type "string" AnimAssistant.PlayblastPt ($getPath);
}

