global proc AnimOffset () {
	global string $animfl;
	global string $animli;
	global string $animnm;
	global string $framest;
	global string $frameen;
	string $animlist = `getAttr AnimAssistant.StartFrame`;
	string $animlien = `getAttr AnimAssistant.EndFrame`;
	string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
	string $animlistarr[] = stringToStringArray($animlist, " ");
	string $animlienarr[] = stringToStringArray($animlien, " ");
	string $animlinmarr[] = stringToStringArray($animlinm, " ");
	string $fannm = `textField -q -tx $animfl`;
	int $site[] = `textScrollList -q -sii $animli`;
	int $ait = `textScrollList -q -ni $animli`;
	int $ststfr = `textField -q -tx $framest` ;
	int $stenfr = `textField -q -tx $frameen` ;
	string $objsfak[] = `textScrollList -q -si $animli`;
	int $indexarr = stringArrayFind( $objsfak[0], 0, $animlinmarr );
	int $diff = $stenfr - (int)$animlienarr[$indexarr];
	int $anlesit = `textScrollList -q -nsi $animli`;

	$animlinmarr[$indexarr] = `substitute ("_" + ($animlistarr[$indexarr]) + "-" + ($animlienarr[$indexarr])) $animlinmarr[$indexarr] ""`;
	$animlienarr[$indexarr] = $stenfr;
	$animlinmarr[$indexarr] = $animlinmarr[$indexarr] + "_" + $animlistarr[$indexarr] + "-"  + $animlienarr[$indexarr];
	if ($anlesit == 1){
		for ($it=0;$it<size($animlinmarr);++$it){;
		$animlinmarr[$it] = `substitute ("_" + ($animlistarr[$it]) + "-" + ($animlienarr[$it])) $animlinmarr[$it] ""`;
		}
		for ($bic = ($indexarr+1); $bic <(size($animlinmarr)); ++$bic){

			$animlienarr[$bic] = (int)$animlienarr[$bic] + $diff;
			$animlistarr[$bic] = (int)$animlistarr[$bic] + $diff;
		}
		for ($ot=0;$ot<size($animlinmarr);++$ot){
		$animlinmarr[$ot] = $animlinmarr[$ot] + "_" + $animlistarr[$ot] + "-"  + $animlienarr[$ot];
		}
	} else if ($anlesit > 1) {
			for ($bac = 1; $bac < $anlesit; ++$bac) {
			int $indexorr = stringArrayFind( $objsfak[$bac], 0, $animlinmarr );
			$animlinmarr[$indexorr] = `substitute ("_" + ($animlistarr[$indexorr]) + "-" + ($animlienarr[$indexorr])) $animlinmarr[$indexorr] ""`;
			$animlienarr[$indexorr] = (int)$animlienarr[$indexorr] + $diff;
			$animlistarr[$indexorr] = (int)$animlistarr[$indexorr] + $diff;
			$animlinmarr[$indexorr] = $animlinmarr[$indexorr] + "_" + $animlistarr[$indexorr] + "-"  + $animlienarr[$indexorr];
		}
	}

	AppendUndo();
	setAttr -type "string" AnimAssistant.AnimationClipName (stringArrayToString($animlinmarr, " "));
	setAttr -type "string" AnimAssistant.StartFrame (stringArrayToString($animlistarr, " "));
	setAttr -type "string" AnimAssistant.EndFrame (stringArrayToString($animlienarr, " "));

	if ($fannm != ""){
			textScrollList -e -ra $animli;
			string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
			string $animlinmarr[] = stringToStringArray($animlinm, " ");
			for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
			}
			string $filteredList[];
			string $aite[] = `textScrollList -q -ai $animli`;
			int $i = 0;
			for ($each in $aite){
					   string $keyword_lower = `tolower $fannm`;
					   string $each_lower = `tolower $each`;

					   string $findMatch = `match $keyword_lower $each_lower `;
					   if ($findMatch == $keyword_lower ){
							   $filteredList[$i] = $each;

							   $i++;
					   }
			 }
			textScrollList -edit -ra $animli;
			 for ($each in $filteredList){
					  textScrollList -edit -append $each $animli;
			 }

		} else {
		textScrollList -e -ra $animli;
			$animlinm = `getAttr AnimAssistant.AnimationClipName`;
			$animlinmarr = stringToStringArray($animlinm, " ");
			for ($ob in $animlinmarr){
			textScrollList -e -a $ob $animli;
			}
		}
		textScrollList -e -sii ($site[0]) $animli;

}

global proc ExptoTOGame () {

	global string $animfl;
	global string $animli;
	global string $animnm;
	global string $framest;
	global string $frameen;
	string $animlist = `getAttr AnimAssistant.StartFrame`;
	string $animlien = `getAttr AnimAssistant.EndFrame`;
	string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
	string $animlistarr[] = stringToStringArray($animlist, " ");
	string $animlienarr[] = stringToStringArray($animlien, " ");
	string $animlinmarr[] = stringToStringArray($animlinm, " ");
	string $objsfak[] = `textScrollList -q -ai $animli`;
	int $ait = `textScrollList -q -ni $animli`;
	int $indexarr = stringArrayFind( $objsfak[0], 0, $animlinmarr );

	for ($tip = 0; $tip < size ($animlinmarr);++$tip){
		string $splitedResult[] = stringToStringArray($animlinmarr[$tip], "|");
		if (size($splitedResult) > 1)
			$animlinmarr[$tip] = $splitedResult[1];
		$animlinmarr[$tip] = `substitute ("_" + ($animlistarr[$tip]) + "-" + ($animlienarr[$tip])) $animlinmarr[$tip] ""`;
	}

	for ($zi = 0; $zi < $ait; ++$zi){
		gameExp_AddNewAnimationClip 1;
		setAttr("gameExporterPreset2.animClips["+$zi+"].animClipStart") ((float)$animlistarr[$zi]);
		setAttr("gameExporterPreset2.animClips["+$zi+"].animClipEnd") ((float)$animlienarr[$zi]);
		setAttr("gameExporterPreset2.animClips["+$zi+"].animClipName") -type "string" $animlinmarr[$zi];

	}

gameExp_CreateExportTypeUIComponents();


}

global proc StoreTakes () {
	global string $animfl;
	global string $animli;
	global string $animnm;
	global string $framest;
	global string $frameen;
	string $animlist = `getAttr AnimAssistant.StartFrame`;
	string $animlien = `getAttr AnimAssistant.EndFrame`;
	string $animlinm = `getAttr AnimAssistant.AnimationClipName`;
	string $animlistarr[] = stringToStringArray($animlist, " ");
	string $animlienarr[] = stringToStringArray($animlien, " ");
	string $animlinmarr[] = stringToStringArray($animlinm, " ");
	string $objsfak[] = `textScrollList -q -ai $animli`;
	int $ait = `textScrollList -q -ni $animli`;
	int $indexarr = stringArrayFind( $objsfak[0], 0, $animlinmarr );

	for ($tip = 0; $tip < size ($animlinmarr);++$tip){
		string $splitedResult[] = stringToStringArray($animlinmarr[$tip], "|");
		if (size($splitedResult) > 1)
			$animlinmarr[$tip] = $splitedResult[1];
		$animlinmarr[$tip] = `substitute ("_" + ($animlistarr[$tip]) + "-" + ($animlienarr[$tip])) $animlinmarr[$tip] ""`;

	}
	FBXExportSplitAnimationIntoTakes -c;
	for ($zi = 0; $zi < $ait; ++$zi){
		FBXExportSplitAnimationIntoTakes -v $animlinmarr[$zi] ((float)$animlistarr[$zi]) ((float)$animlienarr[$zi]);


	}
}


